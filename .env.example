APP_NAME="চোর-ডাকাত-পুলিশ-বাবু"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=true
APP_URL=http://localhost

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chor_dakaat_game
DB_USERNAME=root
DB_PASSWORD=

# Broadcasting - Reverb (uses Pusher protocol internally)
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=chor-dakaat-app
REVERB_APP_KEY=chor-dakaat-key
REVERB_APP_SECRET=chor-dakaat-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# Frontend uses these same values to connect via WebSocket
# REVERB_HOST must be the IP/hostname the browser can reach (not 0.0.0.0)

# Queue (use database for simplicity, or redis)
QUEUE_CONNECTION=database

# Cache
CACHE_STORE=file

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
